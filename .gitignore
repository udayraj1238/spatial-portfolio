# ═══════════════════════════════════════════════════════════════════════════
# GIT IGNORE — Prevent secrets and build artifacts from being committed
# ═══════════════════════════════════════════════════════════════════════════

# ━━━ ENVIRONMENT VARIABLES ━━━ (CRITICAL — never commit these)
.env
.env.local
.env.*.local
.env.production.local
.env.development.local

# ━━━ DEPENDENCIES ━━━
node_modules/
npm-debug.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# ━━━ BUILD & DIST ━━━
.next/
out/
dist/
build/
*.tsbuildinfo

# ━━━ IDE & EDITOR ━━━
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.env.*.local.swp
.eslintcache

# ━━━ OS ━━━
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
.cache

# ━━━ TESTING ━━━
coverage/
.nyc_output/
jest.lcov

# ━━━ MISC ━━━
.turbo/
.vercel/
dummy_padding_for_size_requirement.dat
*.pem

*.zip
